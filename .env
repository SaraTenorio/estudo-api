# Set to "1" to activate the maintenance page for all non-home pages.
# Remove or set to anything other than "1" to disable.
MAINTENANCE_MODE=

# Authentication credentials for the frontend (public) and backend (private).
NEXT_PUBLIC_AUTH_USERNAME=

# Authentication password for the frontend (public) and backend (private).
NEXT_PUBLIC_AUTH_PASSWORD=

# API key for accessing protected resources, available both publicly and privately.
NEXT_PUBLIC_API_KEY=

# API key for accessing protected resources, available both publicly and privately.
API_KEY=

# Authentication username for backend services, not exposed to the frontend.
AUTH_USERNAME=

# Authentication password for backend services, not exposed to the frontend.
AUTH_PASSWORD=

# Secret used to sign and verify JWT tokens (use a long random string in prod).
JWT_SECRET=

# URL pública do resumo JSON publicado pelo CI (usada pela página /qa-report).
# Exemplo:
# QA_REPORT_SUMMARY_URL=https://<teu-blob-store>.public.blob.vercel-storage.com/qa-reports/latest/summary.json
QA_REPORT_SUMMARY_URL=

# Token de escrita do Vercel Blob para publicar relatórios.
# Em produção/CI, configure também como GitHub Secret: BLOB_READ_WRITE_TOKEN.
BLOB_READ_WRITE_TOKEN=

# Prefixo opcional para organização dos relatórios no Blob.
E2E_BLOB_PREFIX=