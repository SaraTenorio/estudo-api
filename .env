# Set to "1" to activate the maintenance page for all non-home pages.
# Remove or set to anything other than "1" to disable.
MAINTENANCE_MODE=1

# Authentication credentials for the frontend (public) and backend (private).
NEXT_PUBLIC_AUTH_USERNAME=

# Authentication password for the frontend (public) and backend (private).
NEXT_PUBLIC_AUTH_PASSWORD=

# API key for accessing protected resources, available both publicly and privately.
NEXT_PUBLIC_API_KEY=

# API key for accessing protected resources, available both publicly and privately.
API_KEY=

# Authentication username for backend services, not exposed to the frontend.
AUTH_USERNAME=

# Authentication password for backend services, not exposed to the frontend.
AUTH_PASSWORD=